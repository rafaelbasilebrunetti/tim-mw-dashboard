# Copie este arquivo para ".env" (na mesma pasta backend/) e preencha os
# valores reais. O arquivo .env nunca deve ser commitado (já está no
# .gitignore).

# Senha única usada para acessar o dashboard (tela de login).
DASHBOARD_PASSWORD=troque-esta-senha

# Chave secreta usada para assinar o cookie de sessão. Use uma string
# aleatória e longa (ex: gere com `python -c "import secrets; print(secrets.token_hex(32))"`).
SESSION_SECRET=troque-esta-chave-aleatoria

# Opcional. Defina como True somente quando o dashboard for servido via
# HTTPS em produção, para o cookie de sessão exigir conexão segura.
COOKIE_SECURE=False
